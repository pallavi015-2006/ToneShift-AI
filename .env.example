# ==========================================================
# ToneShift – Environment Configuration Reference
# Copy this file to ".env" and fill in your actual values.
# NEVER commit your real .env file to version control.
# ==========================================================

# ---- LLM Provider Selection ----
# Supported values: "openai" | "groq" | "openrouter"
LLM_PROVIDER=groq

# ---- OpenAI Configuration ----


# ---- Groq Configuration (used only if LLM_PROVIDER=groq) ----
GROQ_API_KEY=gsk-your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ---- OpenRouter Configuration (used only if LLM_PROVIDER=openrouter) ----


# ---- App Behavior ----
REQUEST_TIMEOUT_SECONDS=30
MAX_INPUT_CHARACTERS=6000
DEFAULT_TEMPERATURE=0.7
